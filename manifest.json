{
  "manifest_version": 3,
  "name": "UdemyPlus",
  "version": "1.1.0",
  "description": "Enhance your Udemy learning with progress tracking and smart video controls.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/course/*/learn/*"],
      "css": [
        "styles/udemyplus.css",
        "libs/css/bootstrap.min.css",
        "libs/css/fontawesome.min.css",
        "libs/css/poppins.css"
      ],
      "js": ["libs/js/interact.min.js", "dist/course-page.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "UdemyPlus"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/css/fontawesome.min.css", "libs/webfonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
